    {
      "name": "Jobs",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const accessKeyId = pm.variables.get('accessKeyId');",
              "const secretKey = pm.variables.get('secretKey');",
              "const accessToken = pm.variables.get('accessToken');",
              "",
              "if (accessToken && accessToken.trim()) {",
              "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${accessToken.trim()}` });",
              "  pm.request.headers.remove('X-Access-Key-Id');",
              "  pm.request.headers.remove('X-Timestamp');",
              "  pm.request.headers.remove('X-Nonce');",
              "  pm.request.headers.remove('X-Signature');",
              "  return;",
              "}",
              "",
              "if (!accessKeyId || !secretKey) {",
              "  throw new Error('Missing accessKeyId/secretKey variables for HMAC signing');",
              "}",
              "",
              "const resolvedAccessKeyId = pm.variables.replaceIn('{{accessKeyId}}');",
              "if (!resolvedAccessKeyId || resolvedAccessKeyId.includes('{{')) {",
              "  throw new Error('accessKeyId is unresolved. Set it in Postman environment or collection variables.');",
              "}",
              "",
              "const timestampMs = String(Date.now());",
              "const nonce = `n-${timestampMs}-${Math.random().toString(16).slice(2, 10)}`;",
              "const method = pm.request.method.toUpperCase();",
              "const pathWithQuery = pm.request.url.getPathWithQuery();",
              "",
              "let rawBody = '';",
              "if (pm.request.body && pm.request.body.mode === 'raw') {",
              "  rawBody = pm.variables.replaceIn(pm.request.body.raw || '');",
              "}",
              "",
              "const bodyHash = CryptoJS.SHA256(rawBody).toString(CryptoJS.enc.Hex);",
              "const canonical = [method, pathWithQuery, timestampMs, nonce, bodyHash].join('\\n');",
              "const signature = CryptoJS.HmacSHA256(canonical, secretKey).toString(CryptoJS.enc.Hex);",
              "",
              "pm.environment.set('xTimestamp', timestampMs);",
              "pm.environment.set('xNonce', nonce);",
              "pm.environment.set('xSignature', signature);",
              "",
              "pm.request.headers.upsert({ key: 'X-Access-Key-Id', value: resolvedAccessKeyId });",
              "pm.request.headers.upsert({ key: 'X-Timestamp', value: timestampMs });",
              "pm.request.headers.upsert({ key: 'X-Nonce', value: nonce });",
              "pm.request.headers.upsert({ key: 'X-Signature', value: signature });"
            ]
          }
        }
      ],
