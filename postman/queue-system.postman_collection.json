            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaults\": {\n    \"executionMode\": \"{{executionMode}}\",\n    \"retryCount\": {{retryCount}},\n    \"delayMs\": {{enqueueDelayMs}},\n    \"job\": {\n      \"name\": \"webhook.dispatch\",\n      \"payload\": {\n        \"endpoint\": \"https://httpbin.org/post\",\n        \"eventType\": \"data.imported\",\n        \"method\": \"POST\"\n      }\n    }\n  },\n  \"items\": [\n    {\n      \"uniqueId\": \"{{uniqueId}}\",\n      \"job\": {\n        \"payload\": {\n          \"data\": {\n            \"recordId\": \"r-1\"\n          }\n        }\n      }\n    },\n    {\n      \"uniqueId\": \"{{uniqueId}}\",\n      \"executionMode\": \"sequential\",\n      \"job\": {\n        \"payload\": {\n          \"data\": {\n            \"recordId\": \"r-2\"\n          }\n        }\n      }\n    }\n  ]\n}"
            },
