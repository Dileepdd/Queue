                  "pm.test('Revoke response has revoked=true', function () {",
                  "  pm.expect(responseJson.revoked).to.eql(true);",
                  "});",
                  "",
                  "const currentAccessKeyId = pm.environment.get('accessKeyId');",
                  "if (responseJson.keyId && currentAccessKeyId && responseJson.keyId === currentAccessKeyId) {",
